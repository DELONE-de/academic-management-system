# Database (Supabase)
# Pooled connection (used by Prisma at runtime via pgBouncer)
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrations)
DIRECT_URL="postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Server
NODE_ENV=development
PORT=5000

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:3000

# Supabase (for file storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI
GEMINI_API_KEY=
GROQ_API_KEY=
